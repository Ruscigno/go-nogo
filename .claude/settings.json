{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/post-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/stop.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm install*)",
      "Bash(pnpm test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm check*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm build*)",
      "Bash(pnpm dev*)",
      "Bash(pnpm audit*)",
      "Bash(pnpm dlx*)",
      "Bash(pnpm exec*)",
      "Bash(pnpx*)",
      "Bash(npx*)",
      "Bash(node*)",
      "Bash(go build*)",
      "Bash(go test*)",
      "Bash(go vet*)",
      "Bash(go mod*)",
      "Bash(go run*)",
      "Bash(gofmt*)",
      "Bash(golangci-lint*)",
      "Bash(govulncheck*)",
      "Bash(sqlc*)",
      "Bash(air*)",
      "Bash(supabase*)",
      "Bash(stripe listen*)",
      "Bash(stripe trigger*)",
      "Bash(wrangler*)",
      "Bash(migrate*)",
      "Bash(gcloud auth*)",
      "Bash(gcloud config*)",
      "Bash(gcloud projects list*)",
      "Bash(gcloud run services list*)",
      "Bash(gcloud run revisions list*)",
      "Bash(gcloud scheduler jobs list*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push origin*)",
      "Bash(git push -u*)",
      "Bash(git rebase*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git stash*)",
      "Bash(git restore*)",
      "Bash(gh pr*)",
      "Bash(gh repo view*)",
      "Bash(gh workflow*)",
      "Bash(gh api*)",
      "Bash(gh run*)",
      "Bash(gitleaks*)",
      "Bash(semgrep*)",
      "Bash(pre-commit*)",
      "Bash(make*)",
      "Bash(docker compose*)",
      "Bash(docker ps*)",
      "Bash(docker logs*)",
      "Bash(psql*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(wc*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(jq*)",
      "Bash(curl http://localhost:*)",
      "Bash(curl http://127.0.0.1:*)",
      "Bash(curl https://aviationweather.gov/*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git reset --hard*)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git push --force *)",
      "Bash(git push -f origin*)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit --amend*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*)",
      "Read(**/service-account*.json)",
      "Read(**/credentials*.json)",
      "Read(**/*-private-key*)",
      "Read(**/*.pem)",
      "Read(**/*.p12)"
    ]
  }
}
