# go-nogo web-app environment template.
# Copy to .env (gitignored) for local dev.

# Frontend listen port (per implementation_plan.md §3.1 + cloudflared template).
PORT=3018

# Where this app calls the Cortex backend (for /me + access guard).
# Production: same-origin via Cloudflared; local dev: direct.
CORTEX_API_URL=http://localhost:8011
CORTEX_HUB_URL=https://aviationcortex.com

# Shared Postgres (gear-private schema: gonogo).
# Connection sets search_path=gonogo,cortex so the gear writes to
# its own schema and reads cortex.* tables transparently.
# Password comes from iac-tickerbeats/infra/.env at runtime.
DATABASE_URL=postgres://gonogo_app:CHANGEME@localhost:5433/cortex?sslmode=disable&search_path=gonogo,cortex

# Shared GoTrue HS256 secret — must match iac-tickerbeats/infra/.env
# and every other gear in the portfolio.
GOTRUE_JWT_SECRET=COPY_FROM_iac-tickerbeats/infra/.env
GOTRUE_JWT_AUDIENCE=authenticated
