{
  "name": "@go-nogo/web-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "go-nogo — SvelteKit gear app for the Aviation Cortex platform (path-routed at aviationcortex.com/go-nogo).",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^22.19.19",
    "prettier": "^3.9.3",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "postgres": "^3.4.9"
  }
}
